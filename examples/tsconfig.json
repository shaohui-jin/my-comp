{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.examples.tsbuildinfo",
    "strict": true,
    "noEmit": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../packages/comp/src/*"],
      "jsh-comp": ["../packages/comp/src/index.ts"],
      "jsh-comp/type": ["../packages/comp/src/type/index.ts"],
      "jsh-comp/type/*": ["../packages/comp/src/type/*"],
      "jsh-tool": ["../packages/tool/src/index.ts"],
      "jsh-tool/*": ["../packages/tool/src/*"],
      "jsh-core": ["../packages/core/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.vue", "env.d.ts"]
}
